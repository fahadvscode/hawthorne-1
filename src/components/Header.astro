---
import { CONTACT } from '../data/project';

const nav = [
  { href: '/floor-plans/', label: 'Floor Plans' },
  { href: '/prices/', label: 'Prices' },
  { href: '/townhomes/', label: 'Townhomes' },
  { href: '/detached/', label: 'Detached' },
  { href: '/location/', label: 'Location' },
  { href: '/faq/', label: 'FAQ' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-forest-mid/10 bg-white/95 text-forest-dark backdrop-blur-sm shadow-sm"
>
  <div class="container-narrow flex items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="group flex items-center gap-3 leading-tight" aria-label="Hawthorne East Village Milton — Home">
      <img src="/images/1780773913252_Hawthrone-East-Village-logo.webp" alt="Hawthorne East Village Logo" class="h-10 w-auto object-contain sm:h-12" />
      <div class="flex flex-col">
        <span class="font-display text-lg font-bold text-forest-dark sm:text-xl">Hawthorne East Village</span>
        <span class="text-xs font-semibold uppercase tracking-wider text-forest-accent">VIP Access · Milton</span>
      </div>
    </a>

    <nav class="hidden items-center gap-5 lg:flex" aria-label="Main navigation">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-semibold transition-colors hover:text-forest-accent',
              currentPath.startsWith(item.href) ? 'text-forest-accent' : 'text-forest-mid',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a href="/register/" class="btn-gold text-xs sm:text-sm">Get VIP Access</a>
    </div>
  </div>
</header>
