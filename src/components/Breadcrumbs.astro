---
import { SITE } from '../data/project';
import { breadcrumbSchema } from '../utils/schema';

interface Crumb {
  name: string;
  path: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;

const schemaItems = [
  { name: 'Home', url: `${SITE.url}/` },
  ...items.map((i) => ({ name: i.name, url: `${SITE.url}${i.path}` })),
];
---

<nav aria-label="Breadcrumb" class="mb-6 text-sm">
  <ol class="flex flex-wrap items-center gap-2 text-forest-mid">
    <li>
      <a href="/" class="hover:text-forest-accent">Home</a>
    </li>
    {
      items.map((item, idx) => (
        <li class="flex items-center gap-2">
          <span aria-hidden="true" class="text-forest-mid/50">/</span>
          {idx === items.length - 1 ? (
            <span class="font-medium text-ink" aria-current="page">
              {item.name}
            </span>
          ) : (
            <a href={item.path} class="hover:text-forest-accent">
              {item.name}
            </a>
          )}
        </li>
      ))
    }
  </ol>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(schemaItems))} />
</nav>
