---
import LeadForm from './LeadForm.astro';
---

<dialog
  id="exit-intent-modal"
  class="fixed inset-0 z-[70] m-auto max-h-[90vh] w-[calc(100%-2rem)] max-w-lg overflow-y-auto rounded-lg border-0 bg-cream p-0 shadow-2xl backdrop:bg-forest-dark/80"
  aria-labelledby="exit-intent-title"
>
  <div class="border-b border-forest-mid/10 bg-forest-dark px-6 py-4 text-cream">
    <div class="flex items-start justify-between gap-4">
      <h2 id="exit-intent-title" class="font-display text-2xl font-semibold text-gold">
        Before you go — get the price list
      </h2>
      <button
        type="button"
        class="min-h-11 min-w-11 rounded text-cream hover:text-gold"
        data-close-exit
        aria-label="Close"
      >
        ✕
      </button>
    </div>
  </div>
  <div class="p-6">
    <p class="mb-4 text-forest-mid">
      VIP registrants receive Hawthorne East Village pricing, floor plans, and incentive details before public
      release.
    </p>
    <LeadForm id="exit-form" variant="inline" formType="exit-intent" />
  </div>
</dialog>

<script>
  const STORAGE_KEY = 'hev_exit_intent_shown';

  function initExitIntent() {
    if (sessionStorage.getItem(STORAGE_KEY)) return;
    if (!window.matchMedia('(min-width: 768px)').matches) return;

    const dialog = document.getElementById('exit-intent-modal') as HTMLDialogElement;
    if (!dialog) return;

    let triggered = false;

    const show = () => {
      if (triggered || sessionStorage.getItem(STORAGE_KEY)) return;
      triggered = true;
      sessionStorage.setItem(STORAGE_KEY, '1');
      dialog.showModal();
    };

    document.addEventListener('mouseout', (e) => {
      const ev = e as MouseEvent;
      if (ev.clientY <= 0 && ev.relatedTarget === null) show();
    });

    document.querySelector('[data-close-exit]')?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }

  initExitIntent();
  document.addEventListener('astro:page-load', initExitIntent);
</script>
