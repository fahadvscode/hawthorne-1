---
import { CONTACT, DISCLAIMER, PROJECT } from '../data/project';

const footerNav = [
  { href: '/', label: 'Home' },
  { href: '/floor-plans/', label: 'Floor Plans' },
  { href: '/prices/', label: 'Prices' },
  { href: '/townhomes/', label: 'Townhomes' },
  { href: '/detached/', label: 'Detached' },
  { href: '/location/', label: 'Location' },
  { href: '/faq/', label: 'FAQ' },
  { href: '/register/', label: 'VIP Registration' },
];
---

<footer class="bg-forest-dark text-cream">
  <div class="section-pad container-narrow">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <p class="font-display text-2xl font-semibold text-gold">{PROJECT.name}</p>
        <p class="mt-2 text-sm text-cream/80">
          Pre-construction by {PROJECT.builder} in {PROJECT.city}, {PROJECT.province}
        </p>
        <p class="mt-4 text-sm font-semibold text-cream">Sold by Fahad · Fahad Javed Real Estate</p>
      </div>

      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-gold">Explore</p>
        <ul class="grid grid-cols-2 gap-2 text-sm">
          {
            footerNav.map((link) => (
              <li>
                <a href={link.href} class="text-cream/80 hover:text-gold">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-gold">Contact</p>
        <address class="not-italic text-sm leading-relaxed text-cream/90">
          <p>
            {CONTACT.name}, {CONTACT.title}
          </p>
          <p>{CONTACT.brokerage}</p>
          <p>{CONTACT.address}</p>
          <p class="mt-2">
            Email:{' '}
            <a href={`mailto:${CONTACT.email}`} class="text-gold hover:underline">
              {CONTACT.email}
            </a>
          </p>
          <p>
            Phone:{' '}
            <a href={`tel:${CONTACT.phoneTel}`} class="text-gold hover:underline">
              {CONTACT.phone}
            </a>
          </p>
          <p>
            Web:{' '}
            <a href={CONTACT.web} class="text-gold hover:underline" rel="noopener noreferrer">
              {CONTACT.webLabel}
            </a>
          </p>
        </address>
      </div>
    </div>

    <div class="mt-12 border-t border-cream/10 pt-8 text-xs leading-relaxed text-cream/70">
      <p>{DISCLAIMER.marketed}</p>
      <p class="mt-2 font-medium text-cream/90">{DISCLAIMER.notOfficial}</p>
      <p class="mt-2">{DISCLAIMER.preliminary}</p>
      <p class="mt-4">
        © {new Date().getFullYear()} {CONTACT.name} · {CONTACT.brokerage}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
