---
import type { FAQ } from '../data/faqs';

interface Props {
  faqs: FAQ[];
  heading?: string;
  id?: string;
}

const { faqs, heading = 'Frequently Asked Questions', id = 'faq' } = Astro.props;
---

<section class="section-pad" aria-labelledby={`${id}-heading`}>
  <div class="container-narrow">
    <h2 id={`${id}-heading`} class="mb-8 text-3xl text-forest-dark">{heading}</h2>
    <div class="space-y-3">
      {
        faqs.map((faq, i) => (
          <details class="faq-item rounded-lg border border-forest-mid/15 bg-white">
            <summary class="flex items-center justify-between gap-4 px-5 py-4 font-semibold text-forest-dark">
              <span>{faq.question}</span>
              <svg
                class="faq-chevron h-5 w-5 shrink-0 text-gold transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="border-t border-forest-mid/10 px-5 pb-4 pt-2 text-forest-mid leading-relaxed">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))
      }
    </div>
    <p class="mt-6 text-sm">
      <a href="/faq/" class="font-semibold text-forest-accent hover:underline">
        View all Hawthorne East Village FAQs →
      </a>
    </p>
  </div>
</section>
