---
import { CONTACT } from '../data/project';
---

<div
  class="fixed bottom-0 left-0 right-0 z-50 flex border-t border-forest-mid/30 bg-forest-dark p-2 shadow-lg md:hidden"
  role="navigation"
  aria-label="Mobile call to action"
>
  <a
    href={`tel:${CONTACT.phoneTel}`}
    class="flex min-h-11 flex-1 items-center justify-center gap-2 rounded-l-md border border-gold/40 bg-forest-mid text-sm font-semibold text-cream"
  >
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
      ></path>
    </svg>
    Call
  </a>
  <a
    href="/register/"
    class="btn-gold flex-1 rounded-l-none rounded-r-md text-sm"
  >
    Register
  </a>
</div>
