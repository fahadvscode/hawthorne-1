---
import LeadForm from './LeadForm.astro';

interface Props {
  h1: string;
  subtitle: string;
  showForm?: boolean;
}

const { h1, subtitle, showForm = true } = Astro.props;
---

<section class="relative overflow-hidden bg-forest-dark text-cream min-h-[85vh] flex items-center">
  <picture class="pointer-events-none absolute inset-0" aria-hidden="true">
    <img
      src="/images/1780773913252_hero_community_picture.webp"
      alt="Hawthorne East Village Milton new home community by Mattamy Homes pre-construction"
      width={1920}
      height={1080}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="h-full w-full object-cover"
    />
  </picture>
  <div class="absolute inset-0 bg-forest-dark/70 sm:bg-transparent sm:bg-gradient-to-r sm:from-forest-dark/95 sm:via-forest-dark/80 sm:to-forest-dark/40" aria-hidden="true"></div>

  <div class="container-narrow relative z-10 grid gap-10 px-4 py-16 sm:px-6 lg:grid-cols-12 lg:items-center lg:py-24">
    <div class="lg:col-span-7">
      <div class="inline-flex items-center gap-2 rounded-full bg-gold/20 px-3 py-1.5 text-sm font-bold text-gold backdrop-blur-md mb-6">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-gold opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-gold"></span>
        </span>
        Register Now for VIP Access
      </div>
      <h1 class="font-display text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl text-balance">
        {h1}
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-cream/90 sm:text-xl leading-relaxed">
        {subtitle}
      </p>
      
      <ul class="mt-8 space-y-3 text-base sm:text-lg text-cream/90 font-medium">
        <li class="flex items-center gap-3">
          <svg class="h-6 w-6 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          Freehold Townhomes & Detached Homes
        </li>
        <li class="flex items-center gap-3">
          <svg class="h-6 w-6 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          Priority Pricing & Floor Plans
        </li>
        <li class="flex items-center gap-3">
          <svg class="h-6 w-6 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          Exclusive VIP Incentives
        </li>
      </ul>

      {
        !showForm && (
          <a href="/register/" class="btn-gold mt-10 inline-flex text-lg px-8 py-4">
            Get VIP Pricing & Floor Plans
          </a>
        )
      }
    </div>

    {
      showForm && (
        <div class="lg:col-span-5">
          <div class="rounded-xl bg-white p-6 shadow-2xl sm:p-8 border-t-4 border-gold relative">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-forest-accent text-white px-4 py-1 rounded-full text-sm font-bold shadow-md whitespace-nowrap">
              Limited Time Access
            </div>
            <div class="text-center mb-6 mt-2">
              <h2 class="text-2xl font-bold text-forest-dark">VIP Registration</h2>
              <p class="text-sm text-forest-mid mt-1">Get floor plans & pricing instantly</p>
            </div>
            <LeadForm id="hero-form" variant="hero" formType="hero" />
          </div>
        </div>
      )
    }
  </div>
</section>

<link rel="preload" as="image" href="/images/1780773913252_hero_community_picture.webp" type="image/webp" fetchpriority="high" />
