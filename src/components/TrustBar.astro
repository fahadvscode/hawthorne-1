---
/**
 * TRUST SIGNALS — replace placeholders before launch:
 * - AGENT_HEADSHOT: /images/fahad-headshot.webp (recommended 120×120, WebP)
 * - BROKERAGE_LOGO: /images/century21-logo.webp (recommended height 40px)
 */
---

<section class="border-y border-forest-mid/10 bg-white py-6" aria-label="Trust signals">
  <div class="container-narrow flex flex-wrap items-center justify-center gap-8 px-4 text-center sm:justify-between sm:text-left">
    <div class="flex items-center gap-4">
      <!-- AGENT_HEADSHOT: uncomment and add src when ready
      <img
        src="/images/fahad-headshot.webp"
        alt="Fahad Javed, Sales Representative — Hawthorne East Village Milton"
        width={64}
        height={64}
        class="h-16 w-16 rounded-full object-cover ring-2 ring-gold"
        loading="lazy"
      />
      -->
      <div class="flex h-16 w-16 items-center justify-center rounded-full bg-forest-mid/10 text-xs text-forest-mid ring-2 ring-gold/50">
        Photo
      </div>
      <div>
        <p class="font-semibold text-forest-dark">Fahad Javed</p>
        <p class="text-sm text-forest-mid">Sales Representative · Century 21 Property Zone Realty Inc.</p>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <!-- BROKERAGE_LOGO: uncomment when ready
      <img src="/images/century21-logo.webp" alt="Century 21 Property Zone Realty Inc." height={40} width={120} loading="lazy" />
      -->
      <p class="max-w-xs text-sm text-forest-mid">
        Independent buyer representation — <strong>we do not represent Mattamy Homes</strong>
      </p>
    </div>
  </div>
</section>
