---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import { pages } from '../../data/seo';
import { CONTACT } from '../../data/project';
---

<BaseLayout title={pages.register.title} description={pages.register.description} path={pages.register.path} ogImage={pages.register.ogImage}>
  <section class="section-pad">
    <div class="container-narrow mx-auto max-w-xl text-center">
      <h1 class="font-display text-4xl font-bold text-forest-dark">{pages.register.h1}</h1>
      <p class="mt-4 text-forest-mid">
        Priority access to Hawthorne East Village pricing, floor plans, deposit schedules, and incentives. Fahad
        will call or text you shortly after registration.
      </p>
    </div>
    <div class="container-narrow mx-auto mt-10 max-w-lg rounded-lg border bg-white p-8 shadow-lg">
      <LeadForm
        id="register-form"
        variant="register"
        formType="register"
        showInterest={true}
        showBudget={true}
        showTimeline={true}
        ctaLabel="Complete VIP Registration"
      />
      <p class="mt-6 text-center text-xs text-forest-mid">
        We do not represent Mattamy Homes. Your information is sent securely to Fahad Javed only.
      </p>
      <p class="mt-4 text-center text-sm">
        Prefer to talk?{' '}
        <a href={`tel:${CONTACT.phoneTel}`} class="font-semibold text-forest-accent">
          {CONTACT.phone}
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
