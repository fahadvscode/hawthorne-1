---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABand from '../../components/CTABand.astro';
import GatedDownload from '../../components/GatedDownload.astro';
import { pages } from '../../data/seo';
import { PROJECT, formatPrice } from '../../data/project';
---

<BaseLayout title={pages.townhomes.title} description={pages.townhomes.description} path={pages.townhomes.path} ogImage={pages.townhomes.ogImage}>
  <section class="section-pad bg-forest-dark text-cream">
    <div class="container-narrow">
      <Breadcrumbs items={[{ name: 'Townhomes', path: '/townhomes/' }]} />
      <h1 class="font-display text-4xl font-bold text-gold sm:text-5xl">{pages.townhomes.h1}</h1>
      <p class="mt-4 max-w-3xl text-lg text-cream/90">
        Hawthorne East Village offers freehold Village townhomes and common-element Rear Lane townhomes in Milton —
        Halton Region freehold and low-rise living by Mattamy Homes.
      </p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow grid gap-10 lg:grid-cols-2">
      <article class="rounded-lg border bg-white p-8">
        <h2 class="text-2xl text-forest-dark">Village Townhomes</h2>
        <p class="mt-3 text-forest-mid">{PROJECT.homeTypes[0].description}</p>
        <ul class="mt-4 space-y-2 text-sm font-medium">
          <li>From {formatPrice(PROJECT.homeTypes[0].priceFrom)}*</li>
          <li>{PROJECT.homeTypes[0].beds} bed · {PROJECT.homeTypes[0].baths} bath</li>
          <li>
            {PROJECT.homeTypes[0].sizeMin.toLocaleString()} – {PROJECT.homeTypes[0].sizeMax.toLocaleString()} sq ft
          </li>
          <li>Freehold ownership</li>
        </ul>
      </article>
      <article class="rounded-lg border bg-white p-8">
        <h2 class="text-2xl text-forest-dark">Rear Lane Townhomes</h2>
        <p class="mt-3 text-forest-mid">{PROJECT.homeTypes[1].description}</p>
        <ul class="mt-4 space-y-2 text-sm font-medium">
          <li>From {formatPrice(PROJECT.homeTypes[1].priceFrom)}*</li>
          <li>{PROJECT.homeTypes[1].beds} bed · {PROJECT.homeTypes[1].baths} bath</li>
          <li>
            {PROJECT.homeTypes[1].sizeMin.toLocaleString()} – {PROJECT.homeTypes[1].sizeMax.toLocaleString()} sq ft
          </li>
          <li>Common-element with rear garage access</li>
        </ul>
      </article>
    </div>
    <p class="container-narrow mt-4 text-xs text-forest-mid">*Starting from, subject to change. E&OE.</p>
    <div class="container-narrow mt-8 flex flex-wrap gap-4">
      <GatedDownload buttonLabel="Get Townhome Pricing" modalTitle="Hawthorne East Village Townhome VIP Package" formType="townhomes" />
      <a href="/floor-plans/" class="btn-outline">View Floor Plans</a>
    </div>
  </section>

  <CTABand />
</BaseLayout>
