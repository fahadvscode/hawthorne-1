---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABand from '../../components/CTABand.astro';
import GatedDownload from '../../components/GatedDownload.astro';
import { pages } from '../../data/seo';
import { PROJECT, formatPrice } from '../../data/project';
---

<BaseLayout title={pages.detached.title} description={pages.detached.description} path={pages.detached.path} ogImage={pages.detached.ogImage}>
  <section class="section-pad bg-forest-dark text-cream">
    <div class="container-narrow">
      <Breadcrumbs items={[{ name: 'Detached Homes', path: '/detached/' }]} />
      <h1 class="font-display text-4xl font-bold text-gold sm:text-5xl">{pages.detached.h1}</h1>
      <p class="mt-4 max-w-3xl text-lg text-cream/90">
        Detached homes at Hawthorne East Village Milton include single-car and double-car garage models from
        approximately {formatPrice(1022990)}, with footprints up to 2,777 square feet.
      </p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-narrow grid gap-10 lg:grid-cols-2">
      <article class="rounded-lg border bg-white p-8">
        <h2 class="text-2xl text-forest-dark">Single-Car Garage Detached</h2>
        <p class="mt-3 text-forest-mid">{PROJECT.homeTypes[2].description}</p>
        <ul class="mt-4 space-y-2 text-sm font-medium">
          <li>From {formatPrice(PROJECT.homeTypes[2].priceFrom)}*</li>
          <li>{PROJECT.homeTypes[2].beds} bed · up to {PROJECT.homeTypes[2].sizeMax.toLocaleString()} sq ft</li>
        </ul>
      </article>
      <article class="rounded-lg border bg-white p-8">
        <h2 class="text-2xl text-forest-dark">Double-Car Garage Detached</h2>
        <p class="mt-3 text-forest-mid">{PROJECT.homeTypes[3].description}</p>
        <ul class="mt-4 space-y-2 text-sm font-medium">
          <li>From {formatPrice(PROJECT.homeTypes[3].priceFrom)}*</li>
          <li>Up to {PROJECT.homeTypes[3].sizeMax.toLocaleString()} sq ft · {PROJECT.homeTypes[3].baths} bath</li>
        </ul>
      </article>
    </div>
    <div class="container-narrow mt-8">
      <img
        src="/images/detached-home.webp"
        alt="Hawthorne East Village Milton double garage detached home elevation by Mattamy Homes"
        width={1200}
        height={500}
        loading="lazy"
        class="w-full rounded-lg object-cover max-h-80"
      />
    </div>
    <div class="container-narrow mt-8 flex flex-wrap gap-4">
      <GatedDownload buttonLabel="Get Detached Pricing" modalTitle="Hawthorne East Village Detached VIP Package" formType="detached" />
      <a href="/prices/" class="btn-outline">View All Prices</a>
    </div>
  </section>

  <CTABand />
</BaseLayout>
